---
import { withBase } from '@config/site';

/**
 * @font-face declarations, base-path correct in BOTH dev and build.
 *
 * Why this is a component and not plain CSS: `url('/fonts/x.woff2')` inside a
 * .css file is only rewritten with the base path at BUILD time. In `astro dev`
 * it stays absolute and 404s, so the site silently renders in fallback fonts
 * during development — the one environment where you would notice a font
 * problem. Building the URL through withBase() makes dev and production agree.
 *
 * Inlined in <head> so the critical faces are declared without an extra
 * round-trip. The metric-matched fallbacks live in fonts.css (no url(), so
 * they are safe there).
 */
const LATIN =
  'U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, ' +
  'U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, ' +
  'U+2193, U+2212, U+2215, U+FEFF, U+FFFD';

const FACES = [
  { family: 'Manrope', style: 'normal', weight: '200 800', file: 'manrope-latin-wght-normal.woff2' },
  { family: 'Inter', style: 'normal', weight: '100 900', file: 'inter-latin-wght-normal.woff2' },
  // Italic only — the serif is used exclusively for the strategic statement.
  { family: 'Source Serif 4', style: 'italic', weight: '200 900', file: 'source-serif-4-latin-wght-italic.woff2' },
];

const css = FACES.map(
  (f) => `@font-face{font-family:'${f.family}';font-style:${f.style};font-weight:${f.weight};` +
    `font-display:swap;src:url('${withBase(`/fonts/${f.file}`)}') format('woff2-variations');` +
    `unicode-range:${LATIN};}`
).join('');

---

<style is:inline set:html={css}></style>
