---
import { Image } from 'astro:assets';
import portrait from '@/assets/portrait/ahmed-hamdy-portrait-approved.webp';
import formulaHome from '@/assets/formula4you/formula4you-platform-home.webp';
import { external, withBase } from '@config/site';
import Disclosure from '@/components/Disclosure.astro';

/**
 * CONTENT NOTE — why this reads the way it does.
 *
 * The previous copy described a method in the abstract: "I map how work moves",
 * "I review clarity and trust". True of every consultant alive, and therefore
 * evidence of nothing. Ahmed's verdict was correct — it read as generated.
 *
 * The rule applied here: every claim is either something he did, something he
 * decided, or something he refused. No adjective stacking. No parallel
 * three-bullet symmetry. Where the evidence stops, the copy says so.
 */

const capabilities = [
  {
    index: '01',
    title: 'Customer Experience & Support Operations',
    teaser: 'The same question arriving hundreds of times is not hundreds of problems. It is one thing upstream that nobody fixed.',
    color: 'signal',
    body: [
      'I spent two years answering Arabic-speaking customers for a UK fintech — remote, high volume, every day. You get fast at the answer. Then you notice the answer is not the point.',
      'Somebody promised something in sales. A page never mentioned a delivery time. A process took three days and told nobody. The complaint lands on support. The cause almost never does.',
      'So I stopped trying to answer faster and started asking why the question existed at all.',
    ],
    leaves: [
      'A contact-driver map — what people actually ask, ranked by how often and how avoidable',
      'Answers written in the customer\'s words, placed at the moment of doubt',
      'An escalation path that names who decides, not just who replies',
      'The list of contacts that should stop existing, and what has to change upstream for that',
    ],
    proof: 'Alpha Capital Group — built the support system, then managed it',
  },
  {
    index: '02',
    title: 'Process & Workflow Improvement',
    teaser: 'A process is not scalable because it has many steps. It is scalable when the right work happens once and the customer never feels the internal complexity.',
    color: 'sky',
    body: [
      'The question I ask first is not "how do we automate this?" It is "what stops existing if we do nothing?"',
      'Most of what looks like a capacity problem is repeated work: the same data asked for twice, a status that lives in one person\'s head, an exception that has no path so it becomes a management interruption.',
      'Automating that makes the waste faster and harder to see. So simplification comes first, always.',
    ],
    leaves: [
      'How the work actually moves — not the diagram somebody drew once',
      'Where it waits, who owns it, and where it becomes invisible',
      'Exception rules, so unusual cases stop being escalations',
      'A written brief the person doing the building can act on',
    ],
    proof: 'Formula4You — listing lifecycle, admin review, governance',
  },
  {
    index: '03',
    title: 'Team Development & Service Quality',
    teaser: 'An agent looks slow. Then you check the cases: they are getting the hard ones. That is a routing problem wearing a performance problem\'s clothes.',
    color: 'violet',
    body: [
      'I did not start as a manager. I started as the person answering — which is why I do not read a quality dashboard the way a manager who never sat in the chair reads it.',
      'Coaching cannot repair a policy that is unfair. Training cannot fix an article nobody can find. Before I say a person is underperforming, I check what the system around them is doing to their work.',
      'When it genuinely is the person, that conversation is easier — because by then they trust that I looked everywhere else first.',
    ],
    leaves: [
      'A quality view that accounts for case mix, not just handling time',
      'Calibration — so two reviewers score the same case the same way',
      'The difference between a knowledge gap, a tools gap, and a judgment gap',
      'Standards for what "good" sounds like, written down instead of assumed',
    ],
    proof: 'Alpha Capital Group — response standards and case guidance',
  },
  {
    index: '04',
    title: 'Customer-Led Business Improvement',
    teaser: 'Customers describe your operating model back to you every day. Most companies file it as tickets.',
    color: 'coral',
    body: [
      'Every objection is a market research interview you already paid for. Every abandoned order is a page that failed to answer something. Every repeated complaint is a process telling you where it breaks.',
      'This is the part I think most businesses waste. The evidence is already in the building — in the inbox, the chat log, the refund reasons — and it gets treated as noise to be cleared rather than signal to be read.',
      'I read it, and turn it into decisions someone can actually take: change the sentence, change the policy, change the sequence, or — occasionally — build the thing.',
    ],
    leaves: [
      'The recurring themes, with what each one is actually costing',
      'Which are content problems, which are policy, which are product',
      'A ranked list — by recurrence, harm, effort and confidence',
      'A decision, an owner, and how we will know if it worked',
    ],
    proof: 'Alpha Capital Group and founder-led commercial work',
  },
];

/**
 * The boundary section. This exists because a portfolio that claims everything
 * proves nothing — and because a company that hires him expecting a designer or
 * a data engineer will be disappointed, which serves nobody.
 */
const lenses = [
  ['Customer Journey & Conversion Review', 'I can tell you where a journey loses people and why — information arriving too late, a decision that needs making twice, a trust signal that is missing. I write the requirement. I do not open Figma and design the screen.'],
  ['Business Performance Interpretation', 'I start from the business question, pick the indicator that actually answers it, and read what the pattern means. I am not a data engineer and I do not build the pipeline.'],
  ['Product Requirements & Prioritization', 'I define the problem, the need, the acceptance logic, and whether building is warranted at all. The architecture and the code belong to engineers.'],
  ['AI-Aware Workflow Decisions', 'I decide where to simplify, where to automate, and where an AI feature would add cost without touching the cause. Knowing when not to build it is the skill. I am not an ML engineer.'],
  ['Digital Commerce & Platform Operations', 'Founder-led: participant journeys, onboarding, trust, operating rules, and coordinating the people who implement. I am not the developer who shipped it.'],
];
---

<div class="home">
  <section class="hero" aria-labelledby="home-title">
    <div class="wrap hero__grid">
      <div class="hero__copy reveal is-visible">
        <p class="eyebrow">Ahmed Hamdy · Business Growth &amp; Operations Specialist</p>
        {/* Three beats, then the turn. The old headline — "Different teams see
            different problems, I connect the pattern" — was true of any
            consultant, which is why it read as generated. This one names three
            departments (the breadth) and lands on the insight that is actually
            his. */}
        <h1 id="home-title">It shows up in support. It slows down sales. <span>It started somewhere else.</span></h1>
        <p class="hero__lede">That gap is my job. I spent two years in the seat where a company's failures arrive as complaints — the clearest view in the building of what is actually broken. I trace a problem back past the department it lands in, and design the smallest change that stops it.</p>
        <p class="hero__depth">Customer Experience · Support Operations · Process Improvement · Team Development · Service Quality</p>
        <div class="cluster hero__actions">
          <a class="btn btn--primary" href="#diagnosis">See how I take it apart <span class="btn__arrow" aria-hidden="true">↓</span></a>
          <a class="btn" href="#evidence">Where I have done it <span class="btn__arrow" aria-hidden="true">→</span></a>
        </div>
      </div>

      <div class="system-lens" aria-label="Customer, support, sales and operations signals converging around Ahmed's portrait">
        <span class="lens-orbit lens-orbit--one"></span>
        <span class="lens-orbit lens-orbit--two"></span>
        <span class="lens-orbit lens-orbit--three"></span>
        <div class="portrait-frame" data-parallax="-0.35">
          <Image src={portrait} alt="Ahmed Hamdy" widths={[360, 540, 720]} sizes="(max-width: 760px) 230px, 300px" loading="eager" />
          <span>Business signal → operating decision</span>
        </div>
        <span class="lens-core">Root cause</span>
        <span class="orbit-node orbit-node--support" data-parallax="0.65">Support signal</span>
        <span class="orbit-node orbit-node--sales" data-parallax="-0.45">Sales friction</span>
        <span class="orbit-node orbit-node--ops" data-parallax="0.5">Operating constraint</span>
        <span class="orbit-node orbit-node--customer" data-parallax="-0.6">Customer behaviour</span>
      </div>
    </div>
  </section>

  <div class="journey" id="diagnosis">
    <svg class="journey__spine" viewBox="0 0 1440 2680" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="journey-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop stop-color="#48e0bb" />
          <stop offset=".34" stop-color="#ff7a61" />
          <stop offset=".68" stop-color="#79b7ff" />
          <stop offset="1" stop-color="#48e0bb" />
        </linearGradient>
      </defs>
      <path class="journey__glow" d="M735 0C720 185 1040 230 930 470C820 700 455 615 510 900C558 1140 1015 1040 960 1320C902 1610 445 1500 520 1810C582 2070 970 1980 814 2680" />
      <path class="journey__line" d="M735 0C720 185 1040 230 930 470C820 700 455 615 510 900C558 1140 1015 1040 960 1320C902 1610 445 1500 520 1810C582 2070 970 1980 814 2680" />
      <circle cx="930" cy="470" r="11" stroke="#ff7a61" />
      <circle cx="510" cy="900" r="11" stroke="#c9f36f" />
      <circle cx="960" cy="1320" r="11" stroke="#79b7ff" />
      <circle cx="520" cy="1810" r="11" stroke="#48e0bb" />
    </svg>

    <section class="signal-section zone-paper">
      <div class="wrap">
        <header class="section-head reveal">
          <div><span class="eyebrow">A worked diagnosis</span><h2>The question reaches support. The cause may sit somewhere else.</h2></div>
          <div><p>Consider a customer asking, “Where is my order?” The answer can close one ticket. The pattern behind the question tells the business what needs to change.</p><span class="scenario-label">Illustrative operating pattern</span></div>
        </header>

        <div class="signal-map">
          <article class="signal-island signal-island--support reveal">
            <span>Support sees</span><h3>The same question, again.</h3>
            <p>Agents repeat the same explanation and the queue grows, even when each conversation is handled well.</p>
          </article>
          <article class="signal-island signal-island--sales reveal reveal-delay-1">
            <span>Sales sees</span><h3>A promise that helped close the order.</h3>
            <p>The offer sounds fast and simple, but the delivery expectation is not specific enough to survive the handoff.</p>
          </article>
          <article class="signal-island signal-island--ops reveal reveal-delay-2">
            <span>Operations sees</span><h3>Status lives inside the team.</h3>
            <p>The order is moving, but the customer cannot see the same information and ownership changes between steps.</p>
          </article>
          <article class="signal-island signal-island--lead reveal reveal-delay-3">
            <span>Management sees</span><h3>A support-volume problem.</h3>
            <p>The pressure is visible in support. That does not mean it started there.</p>
          </article>
          <div class="signal-map__core"><strong>Expectation + visibility + ownership</strong><small>The operating constraint</small></div>
        </div>
      </div>
    </section>

    <section class="decision-section zone-night" id="how-home">
      <div class="wrap decision-shell">
        <header class="section-head reveal">
          <div><span class="eyebrow">From signal to decision</span><h2>Trace the pattern before fixing the symptom.</h2></div>
          <p>My role sits between evidence and execution: make the problem clear, connect the people involved and define a move the business can defend.</p>
        </header>

        {/* These were Understand / Diagnose / Prioritize / Define / Coordinate /
            Measure — the same six words every consultant on earth prints. Same
            structure, but each one now says something only he would say. */}
        <ol class="decision-path reveal">
          <li><span>01</span><h3>Read the raw</h3><p>The actual conversations, not the summary. A summary is already somebody's interpretation of what matters.</p></li>
          <li><span>02</span><h3>Find the promise</h3><p>Someone upstream promised, implied, or failed to mention something. That is usually where it starts.</p></li>
          <li><span>03</span><h3>Ask what disappears</h3><p>Before asking what to build: what stops existing if we change one sentence, one field, one owner?</p></li>
          <li><span>04</span><h3>Write it down</h3><p>The outcome, the rule, the owner, the signal. If it is not written, it is a conversation, not a decision.</p></li>
          <li><span>05</span><h3>Hand it over</h3><p>I brief the specialist who builds it. I do not pretend to be that specialist.</p></li>
          <li><span>06</span><h3>Check honestly</h3><p>Against a baseline agreed beforehand. If it did not move, I say it did not move.</p></li>
        </ol>
        <div class="decision-note reveal"><strong>In this case the answer was three timed updates and one sentence moved earlier on the page. Not a chatbot, not more agents, not a tracking product. The cheapest thing that removed the reason to ask.</strong></div>
      </div>
    </section>

    <section class="impact-section zone-paper">
      <div class="wrap">
        <header class="section-head reveal">
          <div><span class="eyebrow">One system, several outcomes</span><h2>A useful fix improves more than the department where the problem appeared.</h2></div>
          <p>The aim is not to optimize support at the expense of sales, or sales at the expense of operations. The change should strengthen the promise and the way the company delivers it.</p>
        </header>

        <div class="impact-system">
          <article class="impact-petal impact-petal--support reveal"><span>Customer support</span><h3>Fewer avoidable contacts.</h3><p>Agents spend less time explaining information the journey should already provide.</p></article>
          <article class="impact-petal impact-petal--sales reveal reveal-delay-1"><span>Sales</span><h3>A promise that survives the handoff.</h3><p>Expectation-setting becomes part of trust, not something operations has to repair later.</p></article>
          <article class="impact-petal impact-petal--ops reveal reveal-delay-2"><span>Operations</span><h3>Work that is easier to own.</h3><p>Status, exceptions and responsibility are clearer across the complete flow.</p></article>
          <article class="impact-petal impact-petal--lead reveal reveal-delay-3"><span>Leadership</span><h3>Better decisions from the same signals.</h3><p>Recurring demand becomes evidence for process, policy, product and capacity decisions.</p></article>
          <div class="impact-core"><span>Shared result</span><strong>A clearer operating system</strong></div>
        </div>
      </div>
    </section>
  </div>

  <section class="capability-section zone-paper" id="capabilities">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">Where I add depth</span><h2>Four things I can go deep on. Open the one you care about.</h2></div>
        <p>Not a service list. Each one opens onto how I actually think about it, and what you are left holding afterwards.</p>
      </header>

      {/* Collapsed by default: title + a line that has to earn the click.
          Depth exists without the page demanding you read all of it. */}
      <div class="capability-list reveal">
        {capabilities.map((capability) => (
          <Disclosure index={capability.index} title={capability.title} teaser={capability.teaser} tone="paper">
            <div class={`cap-body cap-body--${capability.color}`}>
              {capability.body.map((para) => <p>{para}</p>)}
              <p class="cap-body__k">What you are left holding</p>
              <ul class="cap-body__list">{capability.leaves.map((item) => <li>{item}</li>)}</ul>
              <p class="cap-body__proof">{capability.proof}</p>
            </div>
          </Disclosure>
        ))}
      </div>
    </div>
  </section>

  <section class="proof-section zone-raised" id="evidence">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">Evidence behind the thinking</span><h2>Two different environments shaped the same operating judgment.</h2></div>
        <p>Alpha Capital comes first because it shows customer depth and career progression inside an international company. Formula4You follows as founder-led evidence of ownership and wider business decisions.</p>
      </header>

      <div class="proof-grid">
        {/* The link here pointed at /work/alpha-capital, which does not exist —
            a 404 in the proof section, of all places. On a single-page site the
            depth belongs in a disclosure, not another route. */}
        <article class="alpha-proof reveal">
          <span class="proof-label">Alpha Capital Group · UK fintech, remote · 2024 — present</span>
          <h3>I did not start as the manager. That is the whole point.</h3>
          <p>The five-star reviews on my name are not a manager's metric. They are two years of being the person a frustrated customer actually reached — in Arabic, at the moment they were losing patience. You cannot delegate that view of a company. You have to sit in it.</p>
          <div class="alpha-proof__flow">
            <span>Answered it</span><i></i><span>Noticed the pattern</span><i></i><span>Built the system</span>
          </div>

          <Disclosure
            index="→"
            title="What I actually built there"
            teaser="Not articles. A reason for the question to stop being asked."
            tone="paper"
          >
            <p><strong>The knowledge base.</strong> Not "content" — answers written in the words customers actually used, placed at the moment of doubt rather than filed where only staff could find them. An article titled in company language is an article nobody finds.</p>
            <p><strong>Escalation paths.</strong> Who decides, not just who replies. Most escalations are not hard cases; they are cases where nobody owns the exception, so the whole thing stops until a manager is interrupted.</p>
            <p><strong>Response standards.</strong> So the answer is the same whoever gives it. Inconsistency is not a people problem — it is a governance problem wearing a people problem's clothes.</p>
            <p><strong>The part that mattered most:</strong> working across sales, operations and product, because that is where the causes were. Support was where the failure arrived. It was almost never where it started.</p>
            <p class="alpha-note">
              <strong>Evidence status.</strong> The title Support Team Manager and the progression into it are my own statement — recorded as user-asserted until documentary proof is attached. Employee of the Month and the exact review count are held back until the certificate and review evidence exist; the site says "hundreds of five-star reviews" and no number until then.
            </p>
          </Disclosure>
        </article>

        <article class="formula-proof reveal reveal-delay-1">
          <div class="formula-proof__image"><Image src={formulaHome} alt="The live Formula4You specialist fragrance-commerce platform" widths={[520, 760, 1040]} sizes="(max-width: 900px) 100vw, 42vw" /></div>
          <div class="formula-proof__copy">
            <span class="proof-label">Verified live platform · founder-led work</span>
            <h3>A market gap turned into a working business system.</h3>
            <p>Formula4You proves a different part of the role: market diagnosis, participant journeys, onboarding, trust, operating rules, priorities and coordination across a live specialist platform.</p>
            <p class="formula-proof__role">Founder — Business Growth, Customer Experience &amp; Platform Operations</p>
            <div class="cluster">
              <a class="btn btn--primary" href={withBase('/work/formula4you')}>Read the case</a>
              <a class="btn" href={external.formula4you} rel="noopener">Visit live platform ↗</a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="lenses-section zone-paper">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">Supporting business lenses</span><h2>I can work next to technical specialists without pretending to be one.</h2></div>
        <p>I define the business question, customer need, workflow, priority and success criteria. Designers, engineers and data specialists retain ownership of their craft.</p>
      </header>
      <div class="lens-list">
        {lenses.map(([title, copy], index) => (
          <article class="lens-row reveal">
            <span>{String(index + 1).padStart(2, '0')}</span><h3>{title}</h3><p>{copy}</p>
          </article>
        ))}
      </div>
      <div class="build-rule reveal">
        <span>Simplify</span><i>→</i><span>Automate</span><i>→</i><span>Build</span>
        <p>Building is the last option, not the first reaction. A clearer sentence, fewer fields or better ownership may solve more than a new feature.</p>
        
      </div>
    </div>
  </section>

  <section class="about-strip zone-night">
    <div class="wrap about-strip__grid">
      <div class="about-strip__quote reveal">
        <span class="eyebrow">Why I see problems this way</span>
        <blockquote>When the same question appears hundreds of times, I do not see hundreds of separate problems. I see one part of the system speaking through customers.</blockquote>
      </div>
      <div class="about-strip__copy reveal reveal-delay-1">
        <p>My customer-facing foundation still shapes how I work. It helps me connect customer behaviour, team performance, operating processes and wider business decisions instead of treating each problem in isolation.</p>
        
      </div>
    </div>
  </section>

  {/* The employer/business fork is gone. Asking a visitor to classify
      themselves before they have read anything was a decision they had no
      basis to make — and it split one evidence base into two weaker doors.
      One page, one close. */}
  <section class="routes-section zone-paper" id="talk">
    <div class="wrap">
      <header class="section-head reveal">
        <div><span class="eyebrow">If any of this landed</span><h2>Tell me what is not working. I will tell you where it actually lives.</h2></div>
        <p>Whether you are hiring or you run the business, the first reply is the same: whether the problem fits what I do, and what evidence I would need to answer it properly. If it is not a fit, I will say so.</p>
      </header>

      <div class="close-actions reveal">
        <a class="btn btn--primary" href={withBase('/contact')}>Start a conversation <span class="btn__arrow" aria-hidden="true">→</span></a>
        <a class="btn" href={withBase('/work/formula4you')}>Read the Formula4You case <span class="btn__arrow" aria-hidden="true">→</span></a>
        <a class="btn" href={withBase('/assets/ahmed-hamdy-cv.pdf')}>Download the CV <span class="btn__arrow" aria-hidden="true">↓</span></a>
      </div>
      <p class="close-note reveal">Messages are read and answered personally. No response time is promised, because I will not promise one I cannot keep.</p>
    </div>
  </section>
</div>

<style>
  .hero { position: relative; min-height: 860px; padding: 9.5rem 0 9rem; overflow: hidden; color: var(--white); background: radial-gradient(circle at 84% 22%, rgba(121,183,255,.18), transparent 24rem), radial-gradient(circle at 7% 80%, rgba(72,224,187,.12), transparent 25rem), linear-gradient(135deg,#04151e 0%,#082632 63%,#0a303a 100%); }
  .hero::before { content: ''; position: absolute; inset: 0; opacity: .19; background-image: radial-gradient(rgba(255,255,255,.28) .7px, transparent .7px); background-size: 24px 24px; mask-image: radial-gradient(circle at 36% 36%,black,transparent 66%); }
  .hero::after { content: ''; position: absolute; z-index: 3; left: -5%; right: -5%; bottom: -95px; height: 180px; border-radius: 52% 48% 0 0 / 58% 65% 0 0; background: var(--paper); transform: rotate(-1.2deg); box-shadow: 0 -22px 45px rgba(0,0,0,.08); }
  /* The copy column was 1.02fr against a 450px minimum, which left the headline
     ~450px to hold display type — six cramped lines. The claim is the point of
     the hero; it gets the room. */
  .hero__grid { position: relative; z-index: 4; display: grid; grid-template-columns: minmax(0,1.25fr) minmax(360px,.75fr); align-items: center; gap: clamp(2.5rem,5vw,5rem); }
  .hero__copy h1 { max-width: 820px; margin-top: 1.25rem; font-size: clamp(2.35rem,1.5rem + 2.9vw,4.4rem); line-height: 1.02; letter-spacing: -.045em; }
  .hero__copy h1 span { position: relative; display: inline; color: var(--signal); }
  .hero__copy h1 span::after { content: ''; position: absolute; left: 1%; right: -3%; bottom: -.12em; height: 12px; border-radius: 50%; border-top: 3px solid var(--coral); transform: rotate(-1.2deg); }
  .hero__lede { max-width: 650px; margin-top: 1.7rem; color: rgba(255,255,255,.68); font-size: clamp(1rem,.96rem + .3vw,1.2rem); }
  .hero__depth { max-width: 660px; margin-top: 1.3rem; color: rgba(255,255,255,.45); font: 750 .7rem/1.7 var(--font-head); letter-spacing: .08em; text-transform: uppercase; }
  .hero__actions { margin-top: 2rem; }
  .system-lens { position: relative; min-height: 535px; }
  .lens-orbit { position: absolute; border: 1px solid rgba(255,255,255,.14); border-radius: 48% 52% 57% 43% / 54% 44% 56% 46%; animation: orbit-shape 11s ease-in-out infinite alternate; }
  .lens-orbit--one { inset: 20px 0 5px 5px; transform: rotate(12deg); }
  .lens-orbit--two { inset: 76px 55px 58px 50px; border-color: rgba(72,224,187,.25); transform: rotate(-17deg); animation-delay: -4s; }
  .lens-orbit--three { inset: 132px 115px 108px 105px; border-style: dashed; border-color: rgba(121,183,255,.3); animation-delay: -7s; }
  .portrait-frame { position: absolute; z-index: 4; left: 50%; top: 48%; width: 290px; height: 380px; overflow: hidden; border: 6px solid rgba(255,255,255,.12); border-radius: 28px 12px 36px 16px; background: var(--night-soft); box-shadow: 0 35px 90px rgba(0,0,0,.45), inset 0 0 30px rgba(255,255,255,.08); transform: translate(-50%,-50%) rotate(1.2deg); }
  .portrait-frame img { width: 100%; height: 100%; object-fit: cover; object-position: center 17%; filter: saturate(.84) contrast(1.04); }
  .portrait-frame span { position: absolute; left: 12px; right: 12px; bottom: 12px; padding: .7rem .9rem; color: rgba(255,255,255,.72); border: 1px solid rgba(255,255,255,.14); border-radius: 14px 6px 16px 8px; background: rgba(4,21,30,.78); backdrop-filter: blur(10px); font: 750 .58rem var(--font-head); letter-spacing: .08em; text-transform: uppercase; }
